# ============================================================
# KRATOS v2 - Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# Full reference: docs/ENV.md
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# --- Supabase (Database + Auth + Storage) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Database (Drizzle ORM direct connection) ---
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# --- Redis (Queues + Cache) ---
REDIS_URL=redis://localhost:6379

# --- AI Providers ---
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Trigger.dev (Background Tasks) ---
TRIGGER_SECRET_KEY=your-trigger-dev-secret-key

# --- Observability ---
LANGSMITH_API_KEY=your-langsmith-api-key
SENTRY_DSN=your-sentry-dsn-backend
VITE_SENTRY_DSN=your-sentry-dsn-frontend

# --- Frontend (VITE_ = exposed to browser) ---
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_BASE_URL=http://localhost:3001/v2

# --- Deploy (CI/CD only — configure as GitHub Secrets) ---
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# RAILWAY_TOKEN=              # Staging deploy
# RAILWAY_PRODUCTION_TOKEN=   # Production deploy

# --- Testing (Development only) ---
# TEST_USER_ID=00000000-0000-0000-0000-000000000001
# E2E_USER_EMAIL=test@example.com
# E2E_USER_PASSWORD=testpassword123
